# Environment Variables for Everest Academy Backend
# Copy this file to .env and fill in the values

# Turso Database (required)
TURSO_URL=libsql://everest-academy-ziad-assem1.aws-eu-west-1.turso.io
TURSO_TOKEN=your_turso_token_here

# Google Gemini AI (required for chatbot)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Origins (comma-separated, optional)
CORS_ORIGIN=http://localhost:4000,http://localhost:3000

# Node Environment
NODE_ENV=development
